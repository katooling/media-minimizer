# Minimal single-thread profile for smaller files.
--disable-everything
--enable-gpl
--enable-libx264
--enable-zlib
--enable-protocol=file
--enable-demuxer=mov,matroska,webm,avi,image2
--enable-muxer=mov,image2
--enable-parser=h264,hevc,vp8,vp9,aac,opus,mpeg4video,mjpeg,png
--enable-decoder=h264,hevc,vp8,vp9,aac,opus,mp3,mjpeg,png
--enable-encoder=libx264,aac,mjpeg,png
--enable-filter=scale,fps,format
